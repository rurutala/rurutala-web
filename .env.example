# Like counter MySQL persistence.
# Use either DATABASE_URL/MYSQL_URL or the individual MYSQL_* values.

# DATABASE_URL=mysql://user:password@host:3306/database_name
# MYSQL_URL=mysql://user:password@host:3306/database_name

# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=rurutala_web
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_SSL=true
